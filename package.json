{
  "name": "injury",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worker": "wrangler dev",
    "build": "next build",
    "build:cloudflare": "node scripts/build-cloudflare.js",
    "prepare-worker": "node scripts/prepare-worker.js",
    "deploy:cloudflare": "wrangler deploy --env production --config wrangler.toml",
    "deploy:worker": "npm run deploy:cloudflare",
    "deploy:dry-run": "wrangler deploy --dry-run --env production --config wrangler.toml",
    "d1:migrations:list:production": "wrangler d1 migrations list LEADS_DB --remote --env production --config wrangler.toml",
    "d1:migrations:apply:production": "wrangler d1 migrations apply LEADS_DB --remote --env production --config wrangler.toml",
    "worker:tail": "wrangler tail",
    "start": "next start",
    "image:metadata:audit": "node scripts/image-metadata.mjs audit",
    "image:metadata:strip": "node scripts/image-metadata.mjs strip",
    "image:metadata:check": "node scripts/image-metadata.mjs check",
    "lint": "eslint .",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:lead-scenarios": "node --import tsx --test tests/lead-scenarios.test.ts",
    "test:launch": "npm test && npm run test:lead-scenarios"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slider": "^1.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.511.0",
    "motion": "^12.38.0",
    "next": "15.3.2",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vercel": "^42.2.0"
  }
}
