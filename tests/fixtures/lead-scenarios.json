[
  {
    "id": "valid_cold_attorney_lead",
    "description": "California visitor with an aged minor-impact injury verifies by SMS and queues a cold lead.",
    "base": "soft_tissue",
    "overrides": {
      "accidentDetails": {
        "dateOfAccident": "2025-01-15",
        "impactSeverity": "low"
      }
    },
    "geo": "california",
    "formStartAgeSeconds": 180,
    "routing": "attorney_available",
    "unlock": {
      "mode": "sms_lead",
      "phone": "(949) 555-0101",
      "code": "123456",
      "consent": true,
      "firstName": "Scenario",
      "lastName": "Lead",
      "email": "valid.cold.attorney.lead@example.com"
    },
    "expect": {
      "preview": {
        "unlockMode": "sms_lead",
        "requiresAttorneyConsent": true,
        "leadDeliveryStatus": "preview_attorney_available"
      },
      "deliveryStatus": "ready_for_delivery",
      "qualificationStatus": "valid",
      "verificationStatus": "verified",
      "temperature": "cold",
      "queueCount": 1,
      "payload": {
        "maskedPhone": "(***) ***-0101",
        "encryptedPhoneRefPrefix": "v1.",
        "attorneyId": "scenario-attorney",
        "omitsDateOfBirth": true,
        "encryptedContactRefPrefix": "v1."
      }
    }
  },
  {
    "id": "too_fast_completion",
    "description": "A California visitor who finishes before the lead-quality window receives estimate-only unlock.",
    "base": "soft_tissue",
    "geo": "california",
    "formStartAgeSeconds": 15,
    "routing": "attorney_available",
    "unlock": {
      "mode": "estimate_only"
    },
    "expect": {
      "preview": {
        "unlockMode": "estimate_only",
        "requiresAttorneyConsent": false,
        "leadDeliveryStatus": "too_fast_no_delivery"
      },
      "deliveryStatus": "too_fast_no_delivery",
      "qualificationStatus": "no_sale",
      "verificationStatus": "unverified",
      "temperature": "not_lead",
      "queueCount": 0,
      "reasonsInclude": [
        "too_fast_no_delivery"
      ]
    }
  },
